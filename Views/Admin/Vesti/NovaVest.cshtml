@model HoopLeague.Models.ViewModels.VestListViewModel
@{
    Layout = null;
}

<!doctype html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <title>Admin • Nova vest</title>

    <style>
        :root {
            --adm-bg: #f6f7f9;
            --adm-card: #ffffff;
            --adm-text: #0f172a;
            --adm-muted: #64748b;
            --adm-border: #e2e8f0;
            --adm-shadow: 0 10px 30px rgba(2,6,23,.08);
        }

        body {
            margin: 0;
            font-family: system-ui;
            background: var(--adm-bg);
        }

        .adm-wrap {
            max-width: 900px;
            margin: 40px auto;
            padding: 20px;
        }

        .adm-top {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .adm-title {
            font-size: 26px;
        }

        .adm-card {
            background: white;
            padding: 25px;
            border-radius: 16px;
            box-shadow: var(--adm-shadow);
        }

        .adm-section-title {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .adm-form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .adm-field {
            display: flex;
            flex-direction: column;
        }

            .adm-field label {
                font-size: 13px;
                margin-bottom: 6px;
                color: var(--adm-muted);
            }

        .adm-input {
            padding: 12px;
            border-radius: 10px;
            border: 1px solid var(--adm-border);
        }

            .adm-input:focus {
                outline: none;
                border-color: #ff3c00;
                box-shadow: 0 0 0 2px rgba(255,60,0,0.15);
            }

        textarea.adm-input {
            resize: vertical;
        }

        .adm-actions {
            display: flex;
            justify-content: space-between;
            margin-top: 20px;
        }

        .adm-btn {
            background: linear-gradient(90deg,#ff8c00,#ff3c00);
            color: white;
            padding: 12px 18px;
            border-radius: 10px;
            border: none;
            font-weight: 600;
            cursor: pointer;
        }

        .adm-btn-ghost {
            background: white;
            border: 1px solid var(--adm-border);
            color: black;
        }

        .adm-error {
            color: red;
            font-size: 12px;
        }
    </style>
</head>

<body>

    <div class="adm-wrap">

        <div class="adm-top">
            <h1 class="adm-title">📰 Nova vest</h1>
            <a href="/Admin/Vesti" class="adm-btn adm-btn-ghost">Nazad</a>
        </div>

        <div class="adm-card">

            <form method="post" action="/Admin/Vesti/NovaVest">
                @Html.AntiForgeryToken()

                <div class="adm-section-title">📋 Osnovne informacije</div>

                <div class="adm-form-grid">

                    <div class="adm-field">
                        <label asp-for="Naslov"></label>
                        <input asp-for="Naslov" class="adm-input" />
                        <span asp-validation-for="Naslov" class="adm-error"></span>
                    </div>

                    <div class="adm-field">
                        <label asp-for="UtakmicaId">Utakmica (opciono)</label>
                        <input asp-for="UtakmicaId" type="number" class="adm-input" />
                    </div>

                    <div class="adm-field" style="grid-column: span 2;">
                        <label asp-for="Tekst"></label>
                        <textarea asp-for="Tekst" rows="8" class="adm-input"></textarea>
                        <span asp-validation-for="Tekst" class="adm-error"></span>
                    </div>

                    <div class="adm-field" style="grid-column: span 2;">
                        <label asp-for="SlikaUrl"></label>
                        <input asp-for="SlikaUrl" class="adm-input" />
                    </div>

                </div>

                <div class="adm-actions">
                    <a href="/Admin/Vesti" class="adm-btn adm-btn-ghost">Otkaži</a>
                    <button type="submit" class="adm-btn">Sačuvaj vest</button>
                </div>

            </form>

        </div>

    </div>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>