@model List<HoopLeague.Models.ViewModels.IgraciViewModel>
@{
    Layout = null;
}

<!doctype html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <title>Admin • Igrači</title>

    <style>
        :root {
            --adm-bg: #f6f7f9;
            --adm-card: #ffffff;
            --adm-text: #0f172a;
            --adm-muted: #64748b;
            --adm-border: #e2e8f0;
            --adm-shadow: 0 10px 30px rgba(2,6,23,.08);
        }

        body {
            margin: 0;
            font-family: system-ui;
            background: var(--adm-bg);
            color: var(--adm-text);
        }

        .adm-wrap {
            max-width: 1100px;
            margin: 40px auto;
            padding: 20px;
        }

        /* HEADER */
        .adm-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .adm-title {
            font-size: 26px;
        }

        .adm-subtitle {
            font-size: 14px;
            color: var(--adm-muted);
        }

        /* CARD */
        .adm-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            box-shadow: var(--adm-shadow);
        }

        /* BUTTON */
        .adm-btn {
            background: linear-gradient(90deg, #ff8c00, #ff3c00);
            color: white;
            padding: 10px 16px;
            border-radius: 10px;
            border: none;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
        }

        /* SEARCH */
        .adm-toolbar {
            margin-bottom: 15px;
        }

        .adm-search input {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid var(--adm-border);
            border-radius: 10px;
        }

        /* TABLE */
        .adm-tablewrap {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: #f8fafc;
        }

        th {
            text-align: left;
            padding: 12px;
            font-size: 13px;
            color: #475569;
        }

        td {
            padding: 12px;
            border-top: 1px solid var(--adm-border);
        }

        tr:hover {
            background: #fafafa;
        }

        /* STATUS */
        .adm-pill {
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 12px;
            background: #ecfdf5;
            color: #047857;
            border: 1px solid #a7f3d0;
        }

        /* ACTIONS */
        .adm-actions {
            display: flex;
            gap: 8px;
        }

        .adm-iconbtn {
            padding: 6px 10px;
            border-radius: 8px;
            border: 1px solid var(--adm-border);
            background: white;
            cursor: pointer;
        }

        .adm-iconbtn-danger {
            border-color: #ef4444;
            color: #ef4444;
        }

        .adm-empty {
            text-align: center;
            padding: 20px;
            color: var(--adm-muted);
        }
    </style>
</head>

<body>

    <div class="adm-wrap">

        <!-- HEADER -->
        <div class="adm-top">
            <div>
                <h1 class="adm-title">🏀 Igrači</h1>
                <div class="adm-subtitle">Pregled svih igrača u ligi</div>
            </div>

            <a href="/Admin/Igraci/NoviIgrac" class="adm-btn">
                + Dodaj igrača
            </a>
        </div>

        <!-- CARD -->
        <div class="adm-card">

            <!-- SEARCH -->
            <div class="adm-toolbar">
                <div class="adm-search">
                    <input type="text" placeholder="Pretraži igrače..." />
                </div>
            </div>

            <!-- TABLE -->
            <div class="adm-tablewrap">
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Igrač</th>
                            <th>Tim</th>
                            <th>Pozicija</th>
                            <th>Broj</th>
                            <th>Status</th>
                            <th>Akcije</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            var rb = 1;
                        }

                        @if (Model == null || Model.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="adm-empty">
                                    Nema igrača u bazi.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var igrac in Model)
                            {
                                <tr>
                                    <td>@rb</td>

                                    <td>
                                        <strong>@igrac.Ime @igrac.Prezime</strong>
                                    </td>

                                    <td>@(igrac.Tim ?? "—")</td>

                                    <td>@igrac.Pozicija</td>

                                    <td>#@igrac.BrojDresa</td>

                                    <td>
                                        <span class="adm-pill">Aktivan</span>
                                    </td>

                                    <td>
                                        <div class="adm-actions">

                                            <a href="/Admin/Igraci/IzmeniIgraca/@igrac.IgracId"
                                               class="adm-iconbtn">
                                                ✏️
                                            </a>

                                            <form method="post"
                                                  action="/Admin/Igraci/Obrisi"
                                                  onsubmit="return confirm('Obrisati igrača?');">

                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@igrac.IgracId" />

                                                <button type="submit"
                                                        class="adm-iconbtn adm-iconbtn-danger">
                                                    🗑
                                                </button>
                                            </form>

                                        </div>
                                    </td>
                                </tr>

                                rb++;
                            }
                        }
                    </tbody>
                </table>
            </div>

        </div>

    </div>

</body>
</html>