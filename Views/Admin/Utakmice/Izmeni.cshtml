@model HoopLeague.Models.ViewModels.UtakmicaCreateViewModel
@{
    Layout = null;
    var timovi = ViewBag.Timovi as IEnumerable<dynamic>;
}

<!doctype html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <title>Admin • Izmeni utakmicu</title>
</head>
<style>

    :root {
        --adm-bg: #f6f7f9;
        --adm-card: #ffffff;
        --adm-text: #0f172a;
        --adm-muted: #64748b;
        --adm-border: #e2e8f0;
        --adm-shadow: 0 10px 30px rgba(2, 6, 23, .08);
        --adm-shadow2: 0 14px 40px rgba(2, 6, 23, .12);
    }


    .adm-root, .adm-root * {
        box-sizing: border-box;
    }

    .adm-card {
        padding: 10px;
        border: 1px solid black;
        border-radius: 20px;
        transition: 0.4s;
    }

    .adm-root {
        min-height: 100vh;
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
        background: radial-gradient(1100px 800px at 20% -10%, rgba(15,23,42,.06), transparent 60%), radial-gradient(1100px 800px at 90% 10%, rgba(17,24,39,.05), transparent 55%), var(--adm-bg);
        color: var(--adm-text);
    }


        .adm-root a {
            color: inherit !important;
            text-decoration: none !important;
        }

            .adm-root a:visited {
                color: inherit !important;
            }

            .adm-root a:hover {
                color: inherit !important;
            }

    .adm-wrap {
        max-width: 1040px;
        margin: 0 auto;
        padding: 28px 18px 44px;
    }

    .adm-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 14px;
        margin-bottom: 18px;
    }

    .adm-title {
        margin: 0;
        font-size: 26px;
        letter-spacing: -0.02em;
    }

    .adm-subtitle {
        margin-top: 8px;
        color: var(--adm-muted);
        font-size: 14px;
        line-height: 1.5;
    }

    .adm-chip {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border: 1px solid var(--adm-border);
        background: rgba(255,255,255,.85);
        border-radius: 999px;
        box-shadow: 0 8px 18px rgba(2,6,23,.06);
        color: var(--adm-muted);
        font-size: 13px;
        white-space: nowrap;
    }

    .adm-dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: #22c55e;
        box-shadow: 0 0 0 3px rgba(34,197,94,.15);
    }

    .adm-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        margin-top: 14px;
    }



    .adm-grid {
        grid-template-columns: 1fr;
    }

    }

    .adm-card {
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: var(--adm-card);
        border: 1px solid var(--adm-border);
        border-radius: 18px;
        padding: 16px;
        box-shadow: var(--adm-shadow);
        transition: transform .12s ease, box-shadow .12s ease, border-color .12s ease;
    }

        .adm-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--adm-shadow2);
            border-color: rgba(15,23,42,.22);
        }

    .adm-row {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
    }

    .adm-left {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        min-width: 0;
    }

    .adm-icon {
        width: 40px;
        height: 40px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--adm-border);
        background: #fff;
        font-size: 18px;
        flex: 0 0 40px;
    }

    .adm-cardtitle {
        margin: 0;
        font-size: 16px;
        font-weight: 800;
        letter-spacing: -0.01em;
    }

    .adm-desc {
        margin: 6px 0 0;
        color: var(--adm-muted);
        font-size: 13px;
        line-height: 1.45;
    }

    .adm-badge {
        font-size: 12px;
        color: #334155;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        padding: 6px 10px;
        border-radius: 999px;
        white-space: nowrap;
        align-self: flex-start;
    }

    .adm-foot {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 2px;
        color: var(--adm-muted);
        font-size: 12px;
    }

    .adm-note {
        margin-top: 16px;
        color: var(--adm-muted);
        font-size: 12px;
    }

    .adm-kbd {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        padding: 3px 7px;
        border-radius: 8px;
        border: 1px solid var(--adm-border);
        background: #fff;
        color: #475569;
        font-size: 11px;
    }
</style>
<body class="adm-root">
    <div class="adm-wrap">

        <div class="adm-top">
            <div>
                <h1 class="adm-title">Izmeni utakmicu</h1>
                <div class="adm-subtitle">Izmena zakazane utakmice</div>
            </div>

            <a href="/Admin/Utakmice" class="adm-btn adm-btn-ghost">
                ← Nazad
            </a>
        </div>

        <div class="adm-card">
            <form method="post" action="/Admin/Utakmice/Izmeni">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UtakmicaId" />

                <div class="adm-field">
                    <label>Runda</label>
                    <input asp-for="Runda" type="number" class="adm-input" />
                </div>

                <div class="adm-field">
                    <label>Datum i vreme</label>
                    <input asp-for="DatumVreme"
                           type="datetime-local"
                           class="adm-input" />
                </div>

                <div class="adm-field">
                    <label>Sezona ID</label>
                    <input asp-for="SezonaId"
                           type="number"
                           class="adm-input" />
                </div>

                <div class="adm-field">
                    <label>Domaćin</label>
                    <select asp-for="DomacinTimId" class="adm-input">
                        @foreach (var t in timovi)
                        {
                            <option value="@t.Id"
                                    selected="@(t.Id == Model.DomacinTimId)">
                                @t.Naziv
                            </option>
                        }
                    </select>
                </div>

                <div class="adm-field">
                    <label>Gost</label>
                    <select asp-for="GostTimId" class="adm-input">
                        @foreach (var t in timovi)
                        {
                            <option value="@t.Id"
                                    selected="@(t.Id == Model.GostTimId)">
                                @t.Naziv
                            </option>
                        }
                    </select>
                </div>

                <div class="adm-actions">
                    <button type="submit" class="adm-btn">
                        Sačuvaj izmene
                    </button>

                    <a href="/Admin/Utakmice"
                       class="adm-btn adm-btn-ghost">
                        Otkaži
                    </a>
                </div>
            </form>
        </div>

    </div>
</body>
</html>