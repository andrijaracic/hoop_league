@model HoopLeague.Models.ViewModels.Admin.UtakmicaStatistikaVM
@{
    Layout = null;
}

<!doctype html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <title>Statistika</title>

    <style>
        :root {
            --adm-bg: #f6f7f9;
            --adm-card: #fff;
            --adm-border: #e2e8f0;
            --adm-shadow: 0 10px 30px rgba(0,0,0,0.08);
        }

        body {
            margin: 0;
            font-family: system-ui;
            background: var(--adm-bg);
        }

        .adm-wrap {
            max-width: 1100px;
            margin: 30px auto;
            padding: 20px;
        }

        .adm-title {
            font-size: 26px;
            margin-bottom: 20px;
        }

        .team-title {
            font-size: 20px;
            margin: 30px 0 10px;
        }

        /* IGRAČ */
        .player-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 25px;
            box-shadow: var(--adm-shadow);
        }

        .player-header {
            font-weight: 700;
            margin-bottom: 15px;
        }

        /* ČETVRTINA */
        .quarter {
            border: 1px solid var(--adm-border);
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 15px;
        }

        /* GRID */
        .grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 10px;
        }

        .field {
            display: flex;
            flex-direction: column;
        }

            .field label {
                font-size: 12px;
                color: #64748b;
            }

            .field input {
                padding: 8px;
                border-radius: 8px;
                border: 1px solid var(--adm-border);
            }

        /* BUTTON */
        button {
            margin-top: 10px;
            padding: 10px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(90deg,#ff8c00,#ff3c00);
            color: white;
            font-weight: 600;
            cursor: pointer;
        }

    </style>
</head>

<body>

    <div class="adm-wrap">

        <h1 class="adm-title">🏀 Statistika — utakmica #@Model.UtakmicaId</h1>

        <!-- DOMAĆIN -->
        <h2 class="team-title">Domaćin</h2>

        @foreach (var igrac in Model.DomacinIgraci)
        {
            <div class="player-card">

                <div class="player-header">
                    #@igrac.BrojDresa @igrac.Ime @igrac.Prezime (@igrac.Pozicija)
                </div>

                @for (int q = 1; q <= 4; q++)
                {
                    <div class="quarter">

                        <h4>Četvrtina @q</h4>

                        <form method="post" action="/Admin/Utakmice/Statistika/Unos">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="UtakmicaId" value="@Model.UtakmicaId" />
                            <input type="hidden" name="IgracId" value="@igrac.IgracId" />
                            <input type="hidden" name="Cetvrtina" value="@q" />

                            <div class="grid">

                                <div class="field"><label>Starter</label><input type="number" name="Starter" value="0" /></div>
                                <div class="field"><label>Min</label><input type="number" name="VremeNaTerenu" value="0" /></div>

                                <div class="field"><label>2P pogod.</label><input type="number" name="PogodjenoDvojki" /></div>
                                <div class="field"><label>2P šut</label><input type="number" name="SutnutoDvojki" /></div>

                                <div class="field"><label>3P pogod.</label><input type="number" name="PogodjenoTrojki" /></div>
                                <div class="field"><label>3P šut</label><input type="number" name="SutnutoTrojki" /></div>

                                <div class="field"><label>FT pogod.</label><input type="number" name="PogodjenoSlobodnihBacanja" /></div>
                                <div class="field"><label>FT šut</label><input type="number" name="SutnutoSlobodnihBacanja" /></div>

                                <div class="field"><label>O skok</label><input type="number" name="OfanzivniSkokovi" /></div>
                                <div class="field"><label>D skok</label><input type="number" name="DefanzivniSkokovi" /></div>

                                <div class="field"><label>AST</label><input type="number" name="Asistencije" /></div>
                                <div class="field"><label>STL</label><input type="number" name="UkradeneLopte" /></div>

                                <div class="field"><label>TO</label><input type="number" name="IzgubljeneLopte" /></div>
                                <div class="field"><label>Faul</label><input type="number" name="Faulovi" /></div>

                            </div>

                            <button>Sačuvaj četvrtinu</button>
                        </form>

                    </div>
                }

            </div>
        }

        <!-- GOST -->
        <h2 class="team-title">Gost</h2>

        @foreach (var igrac in Model.GostIgraci)
        {
            <div class="player-card">

                <div class="player-header">
                    #@igrac.BrojDresa @igrac.Ime @igrac.Prezime (@igrac.Pozicija)
                </div>

                @for (int q = 1; q <= 4; q++)
                {
                    <div class="quarter">

                        <h4>Četvrtina @q</h4>

                        <form method="post" action="/Admin/Utakmice/Statistika/Unos">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="UtakmicaId" value="@Model.UtakmicaId" />
                            <input type="hidden" name="IgracId" value="@igrac.IgracId" />
                            <input type="hidden" name="Cetvrtina" value="@q" />

                            <div class="grid">

                                <div class="field"><label>Starter</label><input type="number" name="Starter" /></div>
                                <div class="field"><label>Min</label><input type="number" name="VremeNaTerenu" /></div>

                                <div class="field"><label>2P</label><input type="number" name="PogodjenoDvojki" /></div>
                                <div class="field"><label>2PA</label><input type="number" name="SutnutoDvojki" /></div>

                                <div class="field"><label>3P</label><input type="number" name="PogodjenoTrojki" /></div>
                                <div class="field"><label>3PA</label><input type="number" name="SutnutoTrojki" /></div>

                                <div class="field"><label>FT</label><input type="number" name="PogodjenoSlobodnihBacanja" /></div>
                                <div class="field"><label>FTA</label><input type="number" name="SutnutoSlobodnihBacanja" /></div>

                                <div class="field"><label>OReb</label><input type="number" name="OfanzivniSkokovi" /></div>
                                <div class="field"><label>DReb</label><input type="number" name="DefanzivniSkokovi" /></div>

                                <div class="field"><label>AST</label><input type="number" name="Asistencije" /></div>
                                <div class="field"><label>STL</label><input type="number" name="UkradeneLopte" /></div>

                                <div class="field"><label>TO</label><input type="number" name="IzgubljeneLopte" /></div>
                                <div class="field"><label>F</label><input type="number" name="Faulovi" /></div>

                            </div>

                            <button>Sačuvaj četvrtinu</button>
                        </form>

                    </div>
                }

            </div>
        }

    </div>

</body>
</html>