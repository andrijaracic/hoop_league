@model List<HoopLeague.Models.ViewModels.GameCardViewModel>
@{
    Layout = null;
}

<!doctype html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <title>Admin • Utakmice</title>

    <style>
        :root {
            --adm-bg: #f6f7f9;
            --adm-card: #ffffff;
            --adm-text: #0f172a;
            --adm-muted: #64748b;
            --adm-border: #e2e8f0;
            --adm-shadow: 0 10px 30px rgba(2, 6, 23, .08);
            --adm-shadow2: 0 14px 40px rgba(2, 6, 23, .12);
        }

        body {
            margin: 0;
            font-family: system-ui, Arial;
            background: var(--adm-bg);
            color: var(--adm-text);
        }

        .adm-wrap {
            max-width: 1200px;
            margin: 0 auto;
            padding: 30px;
        }

        .adm-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .adm-title {
            font-size: 28px;
            margin: 0;
        }

        .adm-subtitle {
            color: var(--adm-muted);
            font-size: 14px;
        }

        /* BUTTON */
        .adm-btn {
            background: linear-gradient(90deg, #ff8c00, #ff3c00);
            color: white;
            padding: 10px 16px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            transition: 0.3s;
        }

            .adm-btn:hover {
                transform: translateY(-2px);
            }

        /* CARD */
        .adm-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            box-shadow: var(--adm-shadow);
        }

        /* TABLE */
        .adm-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

            .adm-table thead {
                background: #f1f5f9;
            }

            .adm-table th {
                text-align: left;
                padding: 12px;
                border-bottom: 1px solid #e2e8f0;
            }

            .adm-table td {
                padding: 12px;
                border-bottom: 1px solid #f1f5f9;
            }

            .adm-table tbody tr:hover {
                background: #f8fafc;
            }

        /* STATUS */
        .adm-pill {
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 12px;
            background: #e2e8f0;
        }

        .adm-pill-active {
            background: #dcfce7;
            color: #166534;
        }

        /* ACTIONS */
        .adm-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .adm-iconbtn {
            padding: 6px 10px;
            border-radius: 8px;
            background: #f1f5f9;
            border: 1px solid #e2e8f0;
            font-size: 12px;
            text-decoration: none;
            color: #334155;
            transition: 0.2s;
        }

            .adm-iconbtn:hover {
                background: #e2e8f0;
            }

        .adm-iconbtn-danger {
            background: #fee2e2;
            color: #991b1b;
        }

            .adm-iconbtn-danger:hover {
                background: #fecaca;
            }

        .adm-empty {
            text-align: center;
            padding: 20px;
            color: #64748b;
        }
    </style>
</head>

<body>

    <div class="adm-wrap">

        <div class="adm-top">
            <div>
                <h1 class="adm-title">🏀 Utakmice</h1>
                <div class="adm-subtitle">Zakazane i odigrane utakmice</div>
            </div>

            <a href="/Admin/Utakmice/Nova" class="adm-btn">
                + Zakaži utakmicu
            </a>
        </div>

        <div class="adm-card">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>ID</th>
                        <th>Utakmica</th>
                        <th>Rezultat</th>
                        <th>Datum</th>
                        <th>Runda</th>
                        <th>Status</th>
                        <th>Akcije</th>
                    </tr>
                </thead>

                <tbody>
                    @{
                        var rb = 1;
                    }

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="adm-empty">
                                Nema utakmica.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var u in Model)
                        {
                            var zavrsena = (u.PoeniDomacin + u.PoeniGost) > 0;

                            <tr>
                                <td>@rb</td>
                                <td>@u.UtakmicaId</td>

                                <td>
                                    <strong>@u.Domacin</strong> vs <strong>@u.Gost</strong>
                                </td>

                                <td>
                                    @u.PoeniDomacin : @u.PoeniGost
                                </td>

                                <td>
                                    @u.Datum.ToString("dd.MM.yyyy HH:mm")
                                </td>

                                <td>@u.Runda</td>

                                <td>
                                    @if (zavrsena)
                                    {
                                        <span class="adm-pill adm-pill-active">Završena</span>
                                    }
                                    else
                                    {
                                        <span class="adm-pill">Nije završena</span>
                                    }
                                </td>

                                <td>
                                    <div class="adm-actions">

                                        <a class="adm-iconbtn"
                                           href="/Admin/Utakmice/Izmeni/@u.UtakmicaId">
                                            ✏ Izmeni
                                        </a>

                                        <a class="adm-iconbtn"
                                           href="/Admin/Utakmice/Statistika/Unos/@u.UtakmicaId">
                                            ➕ Unos statistika
                                        </a>

                                        <form method="post"
                                              action="/Admin/Utakmice/Obrisi"
                                              onsubmit="return confirm('Obrisati utakmicu?');"
                                              style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.UtakmicaId" />

                                            <button type="submit"
                                                    class="adm-iconbtn adm-iconbtn-danger">
                                                🗑 Obriši
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            </tr>

                            rb++;
                        }
                    }
                </tbody>
            </table>
        </div>

    </div>

</body>
</html>