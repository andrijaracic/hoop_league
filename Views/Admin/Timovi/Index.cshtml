@model List<HoopLeague.Models.ViewModels.TimListViewModel>
@{
    Layout = null;
}

<!doctype html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <title>Admin • Timovi</title>

    <style>
        :root {
            --adm-bg: #f6f7f9;
            --adm-card: #ffffff;
            --adm-text: #0f172a;
            --adm-muted: #64748b;
            --adm-border: #e2e8f0;
            --adm-shadow: 0 10px 30px rgba(2,6,23,.08);
        }

        body {
            margin: 0;
            font-family: system-ui;
            background: var(--adm-bg);
        }

        /* LAYOUT */
        .adm-wrap {
            max-width: 1100px;
            margin: 40px auto;
            padding: 20px;
        }

        .adm-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .adm-title {
            font-size: 26px;
        }

        /* CARD */
        .adm-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            box-shadow: var(--adm-shadow);
        }

        /* BUTTONS */
        .adm-btn {
            background: linear-gradient(90deg, #ff8c00, #ff3c00);
            color: white;
            padding: 10px 16px;
            border-radius: 10px;
            border: none;
            font-weight: 600;
            cursor: pointer;
        }

        .adm-btn-ghost {
            background: white;
            border: 1px solid var(--adm-border);
            color: black;
        }

        /* TABLE */
        .adm-tablewrap {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: #f8fafc;
        }

        th {
            text-align: left;
            padding: 12px;
            font-size: 13px;
            color: #475569;
        }

        td {
            padding: 12px;
            border-top: 1px solid var(--adm-border);
        }

        tr:hover {
            background: #fafafa;
        }

        /* ACTION BUTTONS */
        .adm-actions {
            display: flex;
            gap: 8px;
        }

        .adm-iconbtn {
            padding: 6px 10px;
            border-radius: 8px;
            border: 1px solid var(--adm-border);
            background: white;
            cursor: pointer;
        }

        .adm-iconbtn-danger {
            border-color: #ef4444;
            color: #ef4444;
        }

        .adm-iconbtn:hover {
            opacity: 0.9;
        }
    </style>
</head>

<body>

    <div class="adm-wrap">

        <div class="adm-top">
            <h1 class="adm-title">🏀 Timovi</h1>

            <a href="/Admin/Timovi/NoviTim" class="adm-btn">
                + Novi tim
            </a>
        </div>

        <div class="adm-card">

            <div class="adm-tablewrap">
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Naziv</th>
                            <th>Grad</th>
                            <th>Država</th>
                            <th>Titule</th>
                            <th>Osnovan</th>
                            <th>Skracenica</th>
                            <th>Boja</th>
                            <th>Akcije</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            var rb = 1;
                        }

                        @if (Model == null || Model.Count == 0)
                        {
                            <tr>
                                <td colspan="9" style="text-align:center; padding:20px;">
                                    Nema timova u bazi.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var t in Model)
                            {
                                <tr>
                                    <td>@rb</td>
                                    <td><strong>@t.Naziv</strong></td>
                                    <td>@t.Grad</td>
                                    <td>@t.Drzava</td>
                                    <td>@t.BrojTitula</td>
                                    <td>
                                        @(t.DatumOsnivanja?.ToString("yyyy") ?? "—")
                                    </td>
                                    <td>@t.Skracenica</td>
                                    <td>@t.Boja</td>

                                    <td>
                                        <div class="adm-actions">

                                            <a href="/Admin/Timovi/Izmeni/@t.TimId"
                                               class="adm-iconbtn">
                                                ✏️
                                            </a>

                                            <form method="post"
                                                  action="/Admin/Timovi/Obrisi"
                                                  onsubmit="return confirm('Da li si siguran?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@t.TimId" />

                                                <button type="submit"
                                                        class="adm-iconbtn adm-iconbtn-danger">
                                                    🗑
                                                </button>
                                            </form>

                                        </div>
                                    </td>
                                </tr>

                                rb++;
                            }
                        }
                    </tbody>
                </table>
            </div>

        </div>

    </div>

</body>
</html>