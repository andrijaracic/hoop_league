@model List<HoopLeague.Models.ViewModels.Admin.HalaListViewModel>
@{
    Layout = null;
}

<!doctype html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <title>Admin • Hale</title>

    <style>
        body {
            font-family: Arial;
            padding: 30px;
        }

        table {
            border-collapse: collapse;
            width: 100%;
            margin-top: 20px;
        }

        th, td {
            border: 1px solid #ddd;
            padding: 8px;
        }

        th {
            background: #f2f2f2;
        }

        a {
            margin-right: 10px;
        }
    </style>
</head>

<body>

    <h1>Hale</h1>

    <a href="/Admin/Hale/Nova">+ Nova hala</a>

    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Naziv</th>
                <th>Grad</th>
                <th>Kapacitet</th>
                <th>Država ID</th>
                <th>Akcije</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6">Nema hala u bazi.</td>
                </tr>
            }
            else
            {
                foreach (var h in Model)
                {
                    <tr>
                        <td>@h.HalaId</td>
                        <td><strong>@h.Naziv</strong></td>
                        <td>@(h.Grad ?? "-")</td>
                        <td>@(h.Kapacitet?.ToString() ?? "-")</td>
                        <td>@h.DrzavaId</td>
                        <td>
                            <a href="/Admin/Hale/Izmeni/@h.HalaId">Edit</a>

                            <form method="post"
                                  action="/Admin/Hale/Obrisi"
                                  style="display:inline"
                                  onsubmit="return confirm('Da li si siguran da želiš da obrišeš ovu halu?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@h.HalaId" />
                                <button type="submit">Obriši</button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

</body>
</html>