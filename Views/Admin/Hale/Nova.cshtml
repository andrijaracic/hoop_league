@model HoopLeague.Models.ViewModels.Admin.HalaListViewModel
@{
    Layout = null;
}

<!doctype html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <title>Nova hala</title>

    <style>
        body {
            font-family: Arial;
            padding: 30px;
        }

        label {
            display: block;
            margin-top: 12px;
        }

        input {
            width: 320px;
            padding: 6px;
        }

        button {
            margin-top: 20px;
            padding: 10px 20px;
        }
    </style>
</head>

<body>

    <h1>Dodaj novu halu</h1>

    <form method="post" action="/Admin/Hale/Nova">
        @Html.AntiForgeryToken()

        <label>Naziv hale</label>
        <input asp-for="Naziv" />

        <label>Država ID</label>
        <input asp-for="DrzavaId" type="number" />

        <label>Kapacitet</label>
        <input asp-for="Kapacitet" type="number" />

        <label>Grad</label>
        <input asp-for="Grad" />

        <label>Adresa</label>
        <input asp-for="Adresa" />

        <label>URL slike</label>
        <input asp-for="UrlSlika" />

        <br />

        <button type="submit">Sačuvaj</button>
        <a href="/Admin/Hale">Otkaži</a>
    </form>

</body>
</html>