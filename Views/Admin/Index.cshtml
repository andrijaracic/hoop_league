@{
    ViewData["Title"] = "Admin";
    Layout = null;
}

<!doctype html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Hoop League Admin</title>

    <style>
        :root {
            --adm-bg: #f6f7f9;
            --adm-card: #ffffff;
            --adm-text: #0f172a;
            --adm-muted: #64748b;
            --adm-border: #e2e8f0;
            --adm-shadow: 0 10px 30px rgba(2,6,23,.08);
        }

        body {
            margin: 0;
            font-family: system-ui;
            background: var(--adm-bg);
        }

        /* WRAP */
        .adm-wrap {
            max-width: 1100px;
            margin: 40px auto;
            padding: 20px;
        }

        /* HEADER */
        .adm-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .adm-title {
            font-size: 28px;
            font-weight: 800;
        }

        .adm-chip {
            padding: 10px 14px;
            border-radius: 999px;
            background: white;
            border: 1px solid var(--adm-border);
            font-size: 13px;
        }

        /* GRID */
        .adm-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 18px;
        }

        /* CARD */
        .adm-card {
            display: block;
            background: white;
            border-radius: 18px;
            padding: 18px;
            border: 1px solid var(--adm-border);
            box-shadow: var(--adm-shadow);
            transition: 0.25s;
        }

            .adm-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 18px 40px rgba(0,0,0,0.12);
            }

        /* CARD CONTENT */
        .adm-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .adm-left {
            display: flex;
            gap: 12px;
        }

        .adm-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f1f5f9;
            font-size: 20px;
        }

        .adm-cardtitle {
            font-size: 16px;
            font-weight: 700;
        }

        .adm-desc {
            font-size: 13px;
            color: var(--adm-muted);
            margin-top: 4px;
        }

        /* FOOT */
        .adm-foot {
            margin-top: 12px;
            font-size: 12px;
            color: var(--adm-muted);
            display: flex;
            justify-content: space-between;
        }

        /* LINKS RESET */
        a {
            text-decoration: none;
            color: inherit;
        }

        /* RESPONSIVE */

        .logout-form {
            display: inline-block;
        }

        /* Dugme */
        .logout-btn {
            padding: 10px 18px;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            background: white;
            color: #0f172a;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

            /* Hover */
            .logout-btn:hover {
                background: #ef4444;
                color: white;
                border-color: #ef4444;
                box-shadow: 0 6px 15px rgba(239,68,68,0.25);
                transform: translateY(-1px);
            }

            /* Click */
            .logout-btn:active {
                transform: scale(0.98);
            }

            /* Fokus */
            .logout-btn:focus {
                outline: none;
                box-shadow: 0 0 0 2px rgba(239,68,68,0.2);
            }
        
    </style>
</head>

<body>

    <div class="adm-wrap">

        <div class="adm-top">
            <h1 class="adm-title">🏀 Admin Panel</h1>
            <div class="adm-chip">Hoop League</div>
        </div>

        <form method="post" action="/AdminAuth/Logout" class="logout-form">
            @Html.AntiForgeryToken()
            <button class="logout-btn">Logout</button>
        </form>

        <div class="adm-grid">

            <a class="adm-card" href="/Admin/Utakmice">
                <div class="adm-row">
                    <div class="adm-left">
                        <div class="adm-icon">🏀</div>
                        <div>
                            <div class="adm-cardtitle">Utakmice</div>
                            <div class="adm-desc">Kreiranje i upravljanje utakmicama</div>
                        </div>
                    </div>
                </div>
                <div class="adm-foot">
                    <span>Rezultat • timovi</span>
                    <span>→</span>
                </div>
            </a>

            <a class="adm-card" href="/Admin/Timovi">
                <div class="adm-row">
                    <div class="adm-left">
                        <div class="adm-icon">🛡️</div>
                        <div>
                            <div class="adm-cardtitle">Timovi</div>
                            <div class="adm-desc">Upravljanje timovima i rosterom</div>
                        </div>
                    </div>
                </div>
                <div class="adm-foot">
                    <span>Roster • sezona</span>
                    <span>→</span>
                </div>
            </a>

            <a class="adm-card" href="/Admin/Igraci">
                <div class="adm-row">
                    <div class="adm-left">
                        <div class="adm-icon">👤</div>
                        <div>
                            <div class="adm-cardtitle">Igrači</div>
                            <div class="adm-desc">Profil i statistika igrača</div>
                        </div>
                    </div>
                </div>
                <div class="adm-foot">
                    <span>Pozicija • broj</span>
                    <span>→</span>
                </div>
            </a>

            <a class="adm-card" href="/Admin/Treneri">
                <div class="adm-row">
                    <div class="adm-left">
                        <div class="adm-icon">🎯</div>
                        <div>
                            <div class="adm-cardtitle">Treneri</div>
                            <div class="adm-desc">Upravljanje trenerima</div>
                        </div>
                    </div>
                </div>
                <div class="adm-foot">
                    <span>Tim • uloga</span>
                    <span>→</span>
                </div>
            </a>

            <a class="adm-card" href="/Admin/Vesti">
                <div class="adm-row">
                    <div class="adm-left">
                        <div class="adm-icon">📰</div>
                        <div>
                            <div class="adm-cardtitle">Vesti</div>
                            <div class="adm-desc">Kreiranje i objava vesti</div>
                        </div>
                    </div>
                </div>
                <div class="adm-foot">
                    <span>Status • utakmica</span>
                    <span>→</span>
                </div>
            </a>

            <a class="adm-card" href="/Admin/Hale">
                <div class="adm-row">
                    <div class="adm-left">
                        <div class="adm-icon">🏟</div>
                        <div>
                            <div class="adm-cardtitle">Hale</div>
                            <div class="adm-desc">Upravljanje halama</div>
                        </div>
                    </div>
                </div>
                <div class="adm-foot">
                    <span>Lokacija • kapacitet</span>
                    <span>→</span>
                </div>
            </a>

        </div>

    </div>

</body>
</html>